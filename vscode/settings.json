{
  // --- Theme ---
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "One Monokai",

  // --- Editor ---
  "editor.fontFamily": "FiraCode Nerd Font Mono, Menlo, Monaco, monospace",
  "editor.fontLigatures": true,
  "editor.rulers": [80, 100],
  "editor.roundedSelection": false,
  "editor.renderWhitespace": "boundary",
  "editor.guides.indentation": true,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.maxColumn": 100,

  // --- Files ---
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // --- Per-language tab sizes ---
  "[typescript]": { "editor.tabSize": 2 },
  "[typescriptreact]": { "editor.tabSize": 2 },
  "[javascript]": { "editor.tabSize": 2 },
  "[javascriptreact]": { "editor.tabSize": 2 },
  "[html]": { "editor.tabSize": 2 },

  // --- Git ---
  "git.autofetch": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",

  // --- Terminal: use fish ---
  "terminal.integrated.defaultProfile.osx": "fish",

  // --- Vim extension ---
  "vim.leader": "<space>",
  "vim.normalModeKeyBindings": [
    { "before": [";"], "after": [":"] }
  ]
}
