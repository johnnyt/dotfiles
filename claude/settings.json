{
  "model": "sonnet",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat 2>/dev/null); case \"$input\" in *SubagentStop*) exit 0 ;; esac; osascript -e 'display notification \"Claude is waiting for input\" with title \"Claude Code\" sound name \"Glass\"' 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "tui": "fullscreen",
  "theme": "dark",
  "verbose": true,
  "preferredNotifChannel": "terminal_bell"
}
